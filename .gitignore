# ---------------------------------------------------------------------------
# Runway .gitignore
# Local-first Windows triage console. Treat anything that touches a real
# tenant, a real device DB, or a signing key as untracked by default.
# ---------------------------------------------------------------------------

# Dependencies
node_modules/
.pnp
.pnp.js
jspm_packages/

# Build outputs
dist/
build/
out/
.vite/
.next/
.turbo/

# Tauri build outputs
src-tauri/target/
src-tauri/gen/
src-tauri/WixTools/
src-tauri/.cargo/

# Test / coverage
coverage/
*.lcov
.nyc_output/
playwright-report/
test-results/
.playwright-cli/

# Local data & secrets — never commit a real tenant's state
data/
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm
.env
.env.local
.env.*.local
.env.production
.env.development

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Tauri signing & code-signing keys — never commit
.tauri/
.runway/
~/
*.key
*.key.pub
*.pem
*.pfx
*.p12

# Claude Code / local agent workspaces
.claude/
.codex/
.tauri-runtime/
.tmp-npm-tree.json
demo/
output/
docs/internal/
CLAUDE.md
CLAUDE.local.md
AGENTS.md
AGENTS.local.md
GEMINI.md
GEMINI.local.md
AI.md
AI.local.md
ai.md
ai.local.md
AI_NOTES.md
AI_NOTES.local.md
ai-notes.md
ai-notes.local.md
agent.md
agent.local.md
agent-notes.md
agent-notes.local.md
*.ai.md
*.agent.md

# Editor / IDE
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.example.json
.history/
*.swp
*.swo
*.bak
*.orig

# OS cruft
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/

# TypeScript incremental builds
*.tsbuildinfo

# Non-Windows icon assets (Windows-only project)
/runway.ico
src-tauri/icons/ios/
src-tauri/icons/android/
src-tauri/icons/icon.icns
