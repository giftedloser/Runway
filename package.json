{
  "name": "pilotcheck",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "Runway — a local-first triage console for Windows Autopilot, Intune, Entra ID, and Graph-derived ConfigMgr client presence. Windows-only by design.",
  "keywords": [
    "autopilot",
    "intune",
    "entra-id",
    "microsoft-graph",
    "configmgr",
    "sccm",
    "windows",
    "endpoint-management",
    "device-triage",
    "tauri",
    "react",
    "typescript",
    "local-first"
  ],
  "author": "Runway contributors",
  "os": [
    "win32"
  ],
  "engines": {
    "node": ">=24.14 <25",
    "npm": ">=11"
  },
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,magenta \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "tsx watch src/server/index.ts | pino-pretty -c",
    "build": "npm run build:client && npm run build:server",
    "build:desktop-runtime": "node scripts/prepare-tauri-runtime.mjs",
    "build:client": "vite build",
    "build:server": "tsup src/server/index.ts --format esm --out-dir dist/server --platform node --target node24 --clean",
    "start": "node dist/server/index.js",
    "db:migrate": "tsx src/server/db/cli.ts migrate",
    "db:seed:mock": "tsx src/server/db/cli.ts seed",
    "test": "vitest run --project unit --project api",
    "test:e2e": "vitest run --project e2e",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run test && npm run test:e2e",
    "check:tauri": "cd src-tauri && cargo fmt --check && cargo clippy -- -D warnings && cargo test",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/giftedloser/PilotCheck.git"
  },
  "bugs": {
    "url": "https://github.com/giftedloser/PilotCheck/issues"
  },
  "homepage": "https://github.com/giftedloser/PilotCheck#readme",
  "dependencies": {
    "@azure/msal-node": "^5.1.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/oswald": "^5.2.8",
    "@fontsource/barlow-condensed": "^5.2.8",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-router": "^1.168.10",
    "@tauri-apps/api": "^2.10.1",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "lucide-react": "^1.7.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@tailwindcss/vite": "^4.1.13",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.3",
    "@types/express-session": "^1.18.2",
    "@types/node": "^24.9.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.38.0",
    "globals": "^16.4.0",
    "jsdom": "^27.0.1",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.6.2",
    "supertest": "^7.1.4",
    "tailwindcss": "^4.1.13",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.0",
    "vite": "^7.1.10",
    "vitest": "^3.2.4"
  }
}
