{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Runway",
  "version": "0.1.0",
  "identifier": "com.giftedloser.pilotcheck",
  "build": {
    "frontendDist": "../dist/client",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build && npm run build:desktop-runtime"
  },
  "app": {
    "windows": [
      {
        "title": "Runway",
        "width": 1520,
        "height": 980,
        "minWidth": 1280,
        "minHeight": 820,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../.tauri-runtime/runtime/": "runtime/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
