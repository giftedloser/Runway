{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Runway",
  "version": "1.6.0",
  "identifier": "com.giftedloser.pilotcheck",
  "build": {
    "frontendDist": "../dist/client",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build && npm run build:desktop-runtime"
  },
  "app": {
    "windows": [
      {
        "title": "Runway",
        "width": 1520,
        "height": 980,
        "minWidth": 1280,
        "minHeight": 820,
        "center": true,
        "resizable": true,
        "decorations": false,
        "shadow": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data: blob:; font-src 'self' data:; connect-src 'self' ipc: http://127.0.0.1:3001 http://localhost:3001 http://127.0.0.1:5173 http://localhost:5173 https://login.microsoftonline.com https://graph.microsoft.com; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": {
      "../.tauri-runtime/runtime/": "runtime/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "signCommand": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/giftedloser/Runway/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENGOTI1MjUwQTgyQTE5OTcKUldTWEdTcW9VRktTenhyZzF3Y2JJRXJtWUNVMlNramh4L3phM0dYOWJza2ZuSEV5UGh2THM5aWUK"
    }
  }
}
