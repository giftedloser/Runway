# Microsoft Graph app registration for read-only ingestion.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=http://localhost:3001/api/auth/callback

# Replace before production/live testing. The server refuses to start outside
# development/test with the built-in default value.
SESSION_SECRET=pilotcheck-dev-session-secret

# Entra sign-in gate before the app loads. It is enforced once Graph
# credentials are configured; set disabled only for local/dev runs.
APP_ACCESS_MODE=entra
APP_ACCESS_ALLOWED_USERS=

PORT=3001
CLIENT_PORT=5173
DATABASE_PATH=./data/pilotcheck.sqlite

SYNC_INTERVAL_MINUTES=15
PROFILE_ASSIGNED_NOT_ENROLLED_HOURS=2
PROVISIONING_STALLED_HOURS=8

# mock = seed/use realistic demo data when live Graph is not configured.
# none = do not seed mock data automatically.
# Use none for live tenant validation to avoid mixing demo and real records.
SEED_MODE=mock

# SCCM / ConfigMgr visibility is enabled in Settings after admin sign-in.
# Runway reads Microsoft Graph / Intune managedDevice.managementAgent only.
# No SCCM site-server connector, SCCM credentials, or SCCM actions are used.

HISTORY_RETENTION_DAYS=90
ACTION_LOG_RETENTION_DAYS=180
SYNC_LOG_RETENTION_DAYS=30
RETENTION_INTERVAL_HOURS=24
