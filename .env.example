# Microsoft Graph app registration for read-only ingestion.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
# Use either a client secret OR a certificate. Certificate auth is
# preferred for production: no rotating string sits on disk, and
# revocation is immediate via the Entra portal. If both are provided,
# the certificate wins.
AZURE_CLIENT_SECRET=
# AZURE_CLIENT_CERT_PATH=C:\path\to\runway-graph.pem
# AZURE_CLIENT_CERT_THUMBPRINT=ABCDEF0123456789ABCDEF0123456789ABCDEF01
AZURE_REDIRECT_URI=http://localhost:3001/api/auth/callback

# If left blank or set to the built-in default, Runway will generate a
# 256-bit random value on first boot and persist it to the runtime .env
# (mode 0600). The server refuses to start outside development/test with
# the built-in default still in place. Set this manually only if you
# have a specific reason (e.g. multi-host deployment with a shared store).
SESSION_SECRET=pilotcheck-dev-session-secret

# Entra sign-in gate before the app loads. It is enforced once Graph
# credentials are configured; set disabled only for local/dev runs.
APP_ACCESS_MODE=entra
APP_ACCESS_ALLOWED_USERS=

PORT=3001
CLIENT_PORT=5173
DATABASE_PATH=./data/pilotcheck.sqlite

# Server log verbosity. Valid values: info, debug, warn, error.
# Defaults to info when omitted.
LOG_LEVEL=info

# Day-to-day operational tunables such as sync interval, rule thresholds,
# retention windows, and mock seed mode are managed in Runway Settings.
# Legacy environment overrides are still honored for automation and
# multi-host installs, but Settings UI values take precedence.

# SCCM / ConfigMgr visibility is enabled in Settings after admin sign-in.
# Runway reads Microsoft Graph / Intune managedDevice.managementAgent only.
# No SCCM site-server connector, SCCM credentials, or SCCM actions are used.
